@startuml vkr_defense_activity
skinparam ActivityBackgroundColor #EEF4FF
skinparam ActivityBorderColor #3A6BC4
skinparam ActivityFontSize 14
skinparam ArrowColor #3A6BC4
skinparam ActivityStartColor #3A6BC4
skinparam ActivityEndColor #C0392B
skinparam ActivityDiamondBackgroundColor #FFF9C4
skinparam ActivityDiamondBorderColor #B8860B

title Процесс подготовки к защите ВКР

start

:Выбор темы ВКР и научного руководителя;
:Составление плана работы;

fork
  :Написание текста ВКР;
  :Введение;
  :Теоретическая часть;
  :Практическая часть;
  :Заключение и выводы;
  :Список литературы и оформление;
fork again
  :Разработка практической части проекта;
  :Тестирование и отладка;
fork again
  :Подготовка презентации;
  :Оформление слайдов;
  :Написание тезисов доклада;
end fork

:Передача текста научному руководителю на проверку;

repeat
  :Получение замечаний от руководителя;
  if (Есть замечания?) then (да)
    :Доработка и исправление текста;
  else (нет)
  endif
repeat while (Текст не утверждён?) is (не утверждён)
->утверждён;

fork
  :Прохождение нормоконтроля;
  repeat
    if (Есть замечания нормоконтролёра?) then (да)
      :Исправление оформления;
    else (нет)
    endif
  repeat while (Нормоконтроль не пройден?) is (не пройден)
  ->пройден;
  :Подпись нормоконтролёра;
fork again
  :Получение отзыва научного руководителя;
fork again
  :Получение рецензии;
end fork

:Предзащита (при наличии);

if (Допущен к защите?) then (да)
  :Сдача документов в деканат\n(заявление, текст ВКР, отзыв, рецензия);
  :Публичная защита ВКР перед комиссией;
  :Ответы на вопросы комиссии;
  :Объявление результатов защиты;
  stop
else (нет)
  :Доработка по замечаниям;
  :Повторная защита;
  stop
endif

@enduml
