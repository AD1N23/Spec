@startuml sequence
skinparam SequenceArrowColor #3A6BC4
skinparam SequenceLifeLineBorderColor #3A6BC4
skinparam SequenceParticipantBackgroundColor #EEF4FF
skinparam SequenceParticipantBorderColor #3A6BC4
skinparam SequenceActorBackgroundColor #EEF4FF
skinparam SequenceActorBorderColor #3A6BC4
skinparam NoteBackgroundColor #FFF9C4
skinparam NoteBorderColor #B8860B
skinparam SequenceGroupBackgroundColor #F0F4FF
skinparam SequenceGroupBorderColor #7A9FD4
skinparam ParticipantPadding 40
skinparam BoxPadding 20

title Диаграмма последовательности — ключевые сценарии бота

actor "Пользователь" as User
participant "Бот" as H
participant "Программа" as FS
participant "База данных" as DB
participant "Сообщения" as MS

== Сценарий 1: Добавление продукта (точное совпадение) ==

User -> H : отправляет текст "Гречка 200"
H -> H : определяет название продукта\nи вес из текста сообщения
H -> FS : ищет продукт "Гречка" в базе
FS -> FS : находит точное совпадение\nи пересчитывает КБЖУ на 200г
FS --> H : возвращает готовую запись
H -> DB : сохраняет запись о приёме пищи
DB --> H : подтверждает сохранение
H -> MS : отправляет подтверждение с КБЖУ
MS --> User : "✅ Гречка 200г — 272 ккал"

== Сценарий 2: Несколько совпадений — выбор продукта ==

User -> H : отправляет текст "Творог 100"
H -> FS : ищет продукт "Творог" в базе
FS --> H : найдено 3 варианта:\nТворог 2%, 5%, 9%
H -> H : запоминает варианты\nдля этого пользователя
H -> MS : отправляет кнопки с вариантами
MS --> User : кнопки выбора продукта

User -> H : нажимает "Творог 5%"
H -> FS : пересчитывает КБЖУ\nТворога 5% на 100г
FS --> H : готовая порция
H -> DB : сохраняет запись о приёме пищи
DB --> H : подтверждает сохранение
H -> H : очищает запомненные варианты
H -> MS : отправляет подтверждение
MS --> User : "✅ Творог 5%, 100г сохранён"

== Сценарий 3: Просмотр отчёта и удаление записи ==

User -> H : нажимает "Отчёт за сегодня"
H -> DB : запрашивает все записи\nпользователя за сегодня
DB --> H : список записей о питании
H -> MS : формирует текст отчёта\nс итогами по КБЖУ
MS --> User : отчёт + кнопка "Редактировать"

User -> H : нажимает "Редактировать"
H -> DB : повторно запрашивает записи
DB --> H : список записей
H -> MS : формирует кнопки\nудаления для каждой записи
MS --> User : список с кнопками ❌

User -> H : нажимает ❌ у записи
H -> DB : удаляет выбранную запись
DB --> H : подтверждает удаление
H -> MS : обновляет список кнопок
MS --> User : обновлённый список

User -> H : нажимает "Готово"
H -> MS : убирает кнопки, показывает итог
MS --> User : финальный отчёт

@enduml
